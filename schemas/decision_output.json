{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SwarmCapitalMarkets Decision Output",
  "type": "object",
  "required": ["decision", "confidence", "rationale"],
  "properties": {
    "decision": {"type": "string", "enum": ["approve", "approve_with_conditions", "restructure", "decline", "watchlist", "distressed_opportunity"]},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "analysis": {
      "type": "object",
      "properties": {
        "cap_rate": {"type": "number"},
        "dscr": {"type": "number"},
        "debt_yield": {"type": "number"},
        "max_loan": {"type": "number"},
        "binding_constraint": {"type": "string", "enum": ["ltv", "dscr", "debt_yield"]},
        "break_even_occupancy": {"type": "number"},
        "levered_irr": {"type": "number"},
        "unlevered_irr": {"type": "number"},
        "equity_multiple": {"type": "number"}
      }
    },
    "risk_flags": {
      "type": "array",
      "items": {"type": "string"},
      "maxItems": 5
    },
    "conditions": {
      "type": "array",
      "items": {"type": "string"}
    },
    "rationale": {"type": "string"},
    "memo_summary": {"type": "string"},
    "scenario_outcomes": {
      "type": "object",
      "properties": {
        "base": {"type": "object"},
        "downside": {"type": "object"},
        "severe": {"type": "object"}
      }
    }
  }
}
